{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Minimal surface: read associated files, open/save dialogs, write a user-chosen attachment path, set window title (§11).",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"core:window:allow-set-title",
		"core:window:allow-set-focus",
		"dialog:allow-open",
		"dialog:allow-save",
		"fs:allow-read-file",
		"fs:allow-write-file",
		{
			"identifier": "fs:scope",
			"allow": [{ "path": "**" }]
		}
	]
}
